# Copy this file to `.env.local` and fill in real values.
# `.env.local` (and `.env`) are gitignored.

# ---------------------------------------------------------------------------
# LiveKit — get these from https://cloud.livekit.io (or your self-hosted server)
# ---------------------------------------------------------------------------
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ---------------------------------------------------------------------------
# Tavus — get the API key from https://platform.tavus.io
#
# All env names here are required.
#
#   TAVUS_FACE_ID     Set this to a Phoenix-3 PRO replica id. Phoenix-3 PRO
#                     is Tavus's lowest-latency face model — recommended
#                     for real-time conversational agents.
#   TAVUS_REPLICA_ID  Alias of TAVUS_FACE_ID; LiveKit's plugin parameter is
#                     strictly called `replica_id`, so we accept either.
#                     (Preferred order: TAVUS_FACE_ID first.)
#
# Each persona MUST be configured with:
#   - pipeline_mode = "echo"
#   - layers.transport.transport_type = "livekit"
# ---------------------------------------------------------------------------
TAVUS_API_KEY=
TAVUS_FACE_ID=
TAVUS_REPLICA_ID=
TAVUS_PERSONA_ID=

# Optional: override the avatar's participant identity in the room.
# Defaults to "Tavus-avatar-agent" if unset. The frontend uses this exact
# string to pick the avatar video track out of `room.remoteParticipants`.
TAVUS_AVATAR_NAME=Tavus-avatar-agent
