# Frontend env vars (mirror in Vercel for production).
# DO NOT commit your real `.env.local`.

# Used by the BROWSER — must be prefixed with NEXT_PUBLIC_.
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# Server-only — read inside /api/token/route.ts.
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=your-livekit-api-key
LIVEKIT_API_SECRET=your-livekit-api-secret
